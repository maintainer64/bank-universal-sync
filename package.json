{
  "name": "bank-universal-sync",
  "repository": "maintainer64/bank-universal-sync",
  "version": "1.0.0",
  "description": "Chrome Extension for universal bank data export ",
  "main": "src/index.tsx",
  "scripts": {
    "start": "vite",
    "build": "vite build && vite build --config vite-service-worker.config.ts && cp -R build bank-universal-sync && zip -r -m build.zip bank-universal-sync",
    "dev": "pnpm build && ./install.sh dev",
    "generate": "npx swagger-typescript-api generate -p https://raw.githubusercontent.com/we-promise/sure/refs/heads/main/docs/api/openapi.yaml -o src/shared/providers/services/sure/sureClient --modular",
    "serve": "vite preview",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "test": "vitest run",
    "test:integration": "vitest run test/sure-integration.test.ts",
    "prepare": "husky"
  },
  "private": false,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/chrome": "^0.2.2",
    "eslint": "^9.39.5",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.64.0",
    "vite": "8.1.4",
    "vite-plugin-progress": "^0.0.7",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@solid-primitives/storage": "^4.4.0",
    "crypto-js": "^4.2.0",
    "isdayoff": "^1.0.1",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.9.14",
    "solid-toast": "^0.5.0"
  },
  "packageManager": "pnpm@11.13.0"
}
